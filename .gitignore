# ================================================================
# SportZie — .gitignore
# ================================================================

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# VS Code
.vscode/
*.code-workspace

# JetBrains IDEs (WebStorm, IntelliJ)
.idea/
*.iml

# Sublime Text
*.sublime-project
*.sublime-workspace

# Brackets
.brackets.json

# Logs
*.log
npm-debug.log*

# Node (in case node_modules ever gets added)
node_modules/
package-lock.json

# Environment files
.env
.env.local
.env.*

# Temporary files
*.tmp
*.temp
*.bak
*.swp
*.swo
*~

# Build / dist output (not applicable now, but good practice)
dist/
build/

# Zip / archive files
*.zip
*.rar
*.tar.gz

# Cache
.cache/
.parcel-cache/
